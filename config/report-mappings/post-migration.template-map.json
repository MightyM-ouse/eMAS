{
  "mappingId": "EMAS-MAP-POSTMIGRATION",
  "mappingVersion": "1.0.0",
  "phaseCode": "POST_MIGRATION",
  "phaseName": "Post-Migration Verification",
  "description": "Technical report-binding contract for the Post-Migration Verification controlled template. Defines exactly where the shared PowerShell reporting engine writes normalized result-object fields, and how the two raw evidence sheets are protected. Contains no business rules, RAG logic, reconciliation logic or discrepancy-classification logic; those remain governed exclusively by the Runtime JSON Contract, Normalized Rule Model and Runtime JSON Schema.",
  "template": {
    "templateId": "EMAS-TPL-POSTMIGRATION",
    "templateName": "eMAS_PostMigration_Template.xlsx",
    "templateVersion": "1.1.1",
    "templateFilePath": "templates/controlled/post-migration/eMAS_PostMigration_Template.xlsx",
    "templateControlTable": "tblPostMigrationTemplateControl"
  },
  "requiredSheetOrder": [
    "01_Executive_Summary",
    "02_Verification_Scope",
    "03_Baseline_vs_Migrated",
    "04_Dossier_Reconciliation",
    "05_Sequence_Reconciliation",
    "06_File_Size_Reconciliation",
    "07_Import_Evidence_Review",
    "08_Discrepancies_&_Actions",
    "09_Accepted_Exceptions",
    "10_Assumptions_&_Limits",
    "11_Review_&_Execution",
    "Import Report Detail",
    "Post Import Verification"
  ],
  "protectedTables": [
    {
      "sheetName": "11_Review_&_Execution",
      "tableName": "tblPostMigrationTemplateControl",
      "protection": "readOnly",
      "preserveHeadersExactly": false,
      "reason": "Release-managed template identity/version/status metadata. Set only at controlled template release, never written by the reporting engine at execution time. The engine may read TemplateVersion/RequiredTableNames from this table for compatibility verification only."
    },
    {
      "sheetName": "Import Report Detail",
      "tableName": "tblRawImportReportDetail",
      "protection": "appendOnly",
      "preserveHeadersExactly": true,
      "reason": "Raw MigrationSummary.xlsx import-report detail. Rows are copied/appended verbatim from the external supplied MigrationSummary.xlsx; the engine must never edit, reorder, delete or reinterpret existing rows, and must never rename, reorder or correct the column headers (including the literal 'Source.Name' header)."
    },
    {
      "sheetName": "Post Import Verification",
      "tableName": "tblRawPostImportVerification",
      "protection": "appendOnly",
      "preserveHeadersExactly": true,
      "reason": "Raw post-import verification evidence. Rows are copied/appended verbatim from the supplied post-import verification source; the engine must never edit, reorder, delete or reinterpret existing rows. The column header 'DossierDirecotry' is preserved exactly as approved and must never be corrected to 'DossierDirectory' by tooling, formatters or spell-checking."
    }
  ],
