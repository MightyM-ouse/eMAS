{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MightyM-ouse/eMAS/blob/requirements/report-redesign-v3.2/config/result-schemas/pre-migration.result.schema.json",
  "title": "eMAS Pre-Migration Result Contract v3.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "phaseCode",
    "resultContractVersion",
    "summaryMetrics",
    "readinessDecision",
    "inputChecks",
    "dossierBaseline",
    "sequenceBaseline",
    "fileTypeBreakdown",
    "fileXmlPathChecks",
    "findings",
    "actions",
    "acceptedExceptions",
    "exclusions",
    "assumptions",
    "limitations",
    "baselineIntegrity",
    "executionDetails"
  ],
  "properties": {
    "phaseCode": {
      "const": "PRE_MIGRATION"
    },
    "resultContractVersion": {
      "type": "string"
    },
    "summaryMetrics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/metricRow"
      }
    },
    "criticalActions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/record"
      }
    },
    "readinessDecision": {
      "$ref": "#/$defs/record"
    },
    "inputChecks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/record"
      }
    },
    "dossierBaseline": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/record"
      }
    },
    "sequenceBaseline": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/record"
      }
    },
    "fileTypeBreakdown": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/record"
      }
    },
    "fileXmlPathChecks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/record"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/record"
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/record"
      }
    },
    "acceptedExceptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/record"
      }
    },
    "exclusions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/record"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/record"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/record"
      }
    },
    "baselineIntegrity": {
      "$ref": "#/$defs/record"
    },
    "executionDetails": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/metricRow"
      }
    }
  },
  "$defs": {
    "stringOrNull": {
      "type": [
        "string",
        "null"
      ]
    },
    "metricRow": {
      "type": "object",
      "required": [
        "section",
        "metric",
        "value",
        "evaluationStatus",
        "valueSource"
      ],
      "properties": {
        "section": {
          "type": "string"
        },
        "metric": {
          "type": "string"
        },
        "value": {},
        "evaluationStatus": {
          "type": "string"
        },
        "rag": {
          "type": [
            "string",
            "null"
          ]
        },
        "confidence": {
          "type": [
            "string",
            "null"
          ]
        },
        "valueSource": {
          "type": "string"
        },
        "reviewRequired": {
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "record": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
