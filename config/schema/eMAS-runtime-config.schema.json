{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MightyM-ouse/eMAS/blob/main/config/schema/eMAS-runtime-config.schema.json",
  "title": "eMAS Runtime Configuration",
  "description": "Effective JSON Schema 1.0.0 for the normalized eMAS runtime configuration exported by the internal XLSM mapping workbook.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "configuration",
    "valueLists",
    "fieldCatalogue",
    "metricCatalogue",
    "masterData",
    "relationships",
    "rules",
    "rulePhases",
    "conditionGroups",
    "ruleConditions",
    "ruleOutputs",
    "findings",
    "recommendations",
    "findingRecommendationLinks",
    "exceptionPolicies",
    "aliases",
    "policies",
    "questionnaireMap",
    "reportTerminology"
  ],
  "properties": {
    "configuration": {
      "$ref": "defs/catalog.schema.json#/$defs/configuration"
    },
    "valueLists": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "defs/common.schema.json#/$defs/identifier"
      },
      "additionalProperties": {
        "type": "array",
        "items": {
          "$ref": "defs/common.schema.json#/$defs/codeValue"
        },
        "minItems": 1
      }
    },
    "fieldCatalogue": {
      "type": "array",
      "items": {
        "$ref": "defs/catalog.schema.json#/$defs/fieldDefinition"
      }
    },
    "metricCatalogue": {
      "type": "array",
      "items": {
        "$ref": "defs/catalog.schema.json#/$defs/metricDefinition"
      }
    },
    "masterData": {
      "$ref": "defs/master-data.schema.json#/$defs/masterData"
    },
    "relationships": {
      "type": "array",
      "items": {
        "$ref": "defs/master-data.schema.json#/$defs/relationship"
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "defs/rules.schema.json#/$defs/rule"
      }
    },
    "rulePhases": {
      "type": "array",
      "items": {
        "$ref": "defs/rules.schema.json#/$defs/rulePhase"
      }
    },
    "conditionGroups": {
      "type": "array",
      "items": {
        "$ref": "defs/rules.schema.json#/$defs/conditionGroup"
      }
    },
    "ruleConditions": {
      "type": "array",
      "items": {
        "$ref": "defs/rules.schema.json#/$defs/condition"
      }
    },
    "ruleOutputs": {
      "type": "array",
      "items": {
        "$ref": "defs/rules.schema.json#/$defs/ruleOutput"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "defs/rules.schema.json#/$defs/finding"
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "$ref": "defs/rules.schema.json#/$defs/recommendation"
      }
    },
    "findingRecommendationLinks": {
      "type": "array",
      "items": {
        "$ref": "defs/rules.schema.json#/$defs/findingRecommendationLink"
      }
    },
    "exceptionPolicies": {
      "type": "array",
      "items": {
        "$ref": "defs/rules.schema.json#/$defs/exceptionPolicy"
      }
    },
    "aliases": {
      "type": "array",
      "items": {
        "$ref": "defs/rules.schema.json#/$defs/alias"
      }
    },
    "policies": {
      "$ref": "defs/policies.schema.json#/$defs/policies"
    },
    "questionnaireMap": {
      "type": "array",
      "items": {
        "$ref": "defs/policies.schema.json#/$defs/questionnaireEntry"
      }
    },
    "reportTerminology": {
      "$ref": "defs/catalog.schema.json#/$defs/reportTerminology"
    }
  }
}
