root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
end_of_line = lf

[*.json]
end_of_line = lf
indent_style = space
indent_size = 2

[*.{yml,yaml}]
end_of_line = lf
indent_style = space
indent_size = 2

[*.{ps1,psm1,psd1,cmd,bat,bas,cls,frm,xaml}]
end_of_line = crlf
indent_style = space
indent_size = 4
